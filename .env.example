# Application
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MSSQL Database
DB_SERVER=your_db_server
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_database
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Redis
REDIS_TYPE=single
REDIS_URL=redis://localhost:6379
REDIS_DEFAULT_TTL=3600
REDIS_DEFAULT_CATALOG_TTL=600
REDIS_DEFAULT_PRODUCTS_TTL=600
REDIS_DEFAULT_PRODUCT_CARD_TTL=300

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_IN=7d

# Domain & API Security
ALLOWED_API_KEYS=test
ALLOWED_DOMAINS=domain1.com,domain2.com

# Sentry
SENTRY_DSN=

# Photos
PHOTOS_BASE_URL=https://example.com/images/
DB_HOST=127.0.0.1